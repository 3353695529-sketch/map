<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>璀璨之光 - 玩家手册</title>

<link rel="icon" type="image/png" href="favicon.png">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#0f1115;
    color:white;
    font-family:"Microsoft YaHei";
}

header{
    background:linear-gradient(135deg,#111827,#1f2937);
    padding:60px 20px;
    text-align:center;
    border-bottom:3px solid #2563eb;
}

header h1{
    font-size:52px;
    color:#60a5fa;
    margin-bottom:15px;
}

header p{
    color:#cbd5e1;
    font-size:18px;
}

.top-buttons{
    margin-top:25px;
}

.top-buttons a{
    display:inline-block;
    margin:8px;
    padding:12px 22px;
    background:#2563eb;
    border-radius:10px;
    text-decoration:none;
    color:white;
    transition:0.2s;
}

.top-buttons a:hover{
    background:#3b82f6;
}

nav{
    position:sticky;
    top:0;
    background:#111827;
    padding:15px;
    border-bottom:1px solid #374151;
    z-index:999;
}

nav ul{
    display:flex;
    gap:15px;
    overflow-x:auto;
    list-style:none;
}

nav a{
    color:#93c5fd;
    text-decoration:none;
    white-space:nowrap;
    padding:8px 15px;
    border-radius:8px;
}

nav a:hover{
    background:#2563eb;
    color:white;
}

.container{
    width:95%;
    max-width:1300px;
    margin:auto;
    padding:40px 0;
}

section{
    background:#161b22;
    margin-bottom:35px;
    padding:30px;
    border-radius:18px;
    border:1px solid #2d3748;
}

section h2{
    color:#60a5fa;
    margin-bottom:25px;
    font-size:34px;
}

section h3{
    color:#93c5fd;
    margin-top:20px;
    margin-bottom:10px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:20px;
}

.card{
    background:#1f2937;
    padding:20px;
    border-radius:14px;
    border:1px solid #374151;
}

.card h3{
    margin-top:0;
}

.tag{
    display:inline-block;
    padding:5px 10px;
    border-radius:8px;
    font-size:12px;
    margin-bottom:10px;
    font-weight:bold;
}

.red{background:#7f1d1d;}
.blue{background:#1e3a8a;}
.green{background:#166534;}
.yellow{background:#92400e;}
.white{background:#6b7280;}
.black{background:#000000;}

.map-container{
    position:relative;
    margin-top:20px;
}

.map-image{
    width:100%;
    border-radius:16px;
    border:2px solid #374151;
}

.zone{
    position:absolute;
    border-radius:50%;
    transform:translate(-50%,-50%);
    opacity:0.55;
    border:2px solid white;
}

.zone:hover{
    opacity:0.9;
}

footer{
    text-align:center;
    padding:40px 20px;
    border-top:1px solid #374151;
    color:#94a3b8;
}

</style>
</head>

<body>

<header>

<h1 id="server-name">加载中...</h1>

<p id="server-subtitle"></p>

<div class="top-buttons">

<a id="website-btn" target="_blank">官方网站</a>

<a id="discord-btn" target="_blank">Discord</a>

</div>

</header>

<nav>

<ul>
<li><a href="#intro">服务器简介</a></li>
<li><a href="#map">游戏地图</a></li>
<li><a href="#zones">区域规则</a></li>
<li><a href="#factions">阵营介绍</a></li>
<li><a href="#rules">服务器规则</a></li>
</ul>

</nav>

<div class="container">

<section id="intro">

<h2>服务器简介</h2>

<p>
欢迎来到《璀璨之光》。
这是一个融合 PVP、PVE 与轻度角色扮演（Light RP）的中文末日生存服务器。
整个世界由玩家共同创造与推动。
</p>

</section>

<section id="map">

<h2 id="map-title">游戏地图</h2>

<div class="map-container">

<img id="map-image" class="map-image">

<div id="zones-container"></div>

</div>

</section>

<section id="zones">

<h2>区域规则</h2>

<div class="grid" id="zones-grid"></div>

</section>

<section id="factions">

<h2>阵营介绍</h2>

<div class="grid" id="factions-grid"></div>

</section>

<section id="rules">

<h2>服务器规则</h2>

<div class="grid">

<div class="card">

<h3>重点规则</h3>

<ul id="important-rules"></ul>

</div>

<div class="card">

<h3>基地规则</h3>

<ul id="building-rules"></ul>

</div>

<div class="card">

<h3>聊天规则</h3>

<ul id="chat-rules"></ul>

</div>

</div>

</section>

</div>

<footer>

<p>QQ群：686854228</p>

<p>希望你能找到属于自己的生存方式。</p>

</footer>

<script>

fetch("config.json")
.then(res => res.json())
.then(data => {

    // 服务器信息
    document.getElementById("server-name").innerText =
        data.server.name;

    document.getElementById("server-subtitle").innerText =
        data.server.subtitle;

    document.getElementById("website-btn").href =
        data.server.website;

    document.getElementById("discord-btn").href =
        data.server.discord;

    // 地图
    document.getElementById("map-title").innerText =
        "当前地图：" + data.map.name;

    document.getElementById("map-image").src =
        data.map.image;

    // 地图区域
    const zonesContainer =
        document.getElementById("zones-container");

    const zonesGrid =
        document.getElementById("zones-grid");

    data.map.zones.forEach(zone => {

        // 地图圆圈
        const circle = document.createElement("div");

        circle.className =
            "zone " + zone.color;

        circle.style.left = zone.x + "%";

        circle.style.top = zone.y + "%";

        circle.style.width = zone.radius + "px";

        circle.style.height = zone.radius + "px";

        circle.title =
            zone.name + " - " + zone.description;

        zonesContainer.appendChild(circle);

        // 区域卡片
        zonesGrid.innerHTML += `
            <div class="card">
                <div class="tag ${zone.color}">
                    ${zone.name}
                </div>

                <h3>${zone.type}</h3>

                <p>${zone.description}</p>
            </div>
        `;
    });

    // 阵营
    const factionsGrid =
        document.getElementById("factions-grid");

    data.factions.forEach(faction => {

        factionsGrid.innerHTML += `
            <div class="card">

                <h3>${faction.name}</h3>

                <p>${faction.description}</p>

                <br>

                <b>类型：</b>
                ${faction.type}

            </div>
        `;
    });

    // 规则
    function addRules(id, rules){

        const element =
            document.getElementById(id);

        rules.forEach(rule => {

            element.innerHTML += `
                <li>${rule}</li>
            `;
        });
    }

    addRules(
        "important-rules",
        data.rules.important
    );

    addRules(
        "building-rules",
        data.rules.building
    );

    addRules(
        "chat-rules",
        data.rules.chat
    );

});

</script>

</body>
</html>
